---
interface Props {
  title: string;
  bio: string[];
}

const { title, bio } = Astro.props;
---

<section class="about section" id="about">
  <div class="about__wrap">
    <div class="about__media" aria-hidden="true">
      <img
        src={`${import.meta.env.BASE_URL}photo-dra.png`}
        alt=""
        class="about__photo"
        width="336"
        height="448"
        loading="lazy"
      />
    </div>
    <div class="about__content">
      <h2 class="about__title">{title}</h2>
      <div class="about__bio">
        {bio.map((text) => <p>{text}</p>)}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background-color: var(--color-bg-warm);
    position: relative;
    z-index: 1;
  }

  .about__wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  @media (min-width: 48rem) {
    .about__wrap {
      flex-direction: row;
      align-items: stretch;
      gap: var(--space-xl);
      padding: 0 var(--space-lg);
    }
  }

  .about__media {
    flex: 0 0 auto;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 48rem) {
    .about__media {
      width: 30%;
      max-width: 14rem;
      align-self: stretch;
      display: block;
    }
  }

  .about__photo {
    width: 100%;
    aspect-ratio: 3 / 4;
    max-height: 280px;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-lg);
    display: block;
  }

  @media (min-width: 48rem) {
    .about__photo {
      width: 100%;
      max-width: 100%;
      height: 100%;
      min-height: 280px;
      max-height: none;
      aspect-ratio: auto;
      object-fit: cover;
      object-position: center top;
    }
  }

  .about__content {
    flex: 1 1 auto;
    min-width: 0;
    position: relative;
  }

  @media (min-width: 48rem) {
    .about__content {
      flex: 0 1 70%;
      min-height: 0;
      display: flex;
      flex-direction: column;
    }
  }

  .about__title {
    /* Visually hidden, kept in DOM for SEO */
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .about__bio {
    width: 100%;
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  @media (min-width: 48rem) {
    .about__bio {
      flex: 1 1 auto;
      min-height: 0;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }

  .about__bio p {
    margin-bottom: var(--space-sm);
  }
</style>
