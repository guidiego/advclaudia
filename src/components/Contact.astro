---
interface Props {
  title: string;
  subtitle: string;
  whatsappButtonText: string;
  whatsappNumber: string;
  whatsappMessage: string;
}

const { title, subtitle, whatsappButtonText, whatsappNumber, whatsappMessage } = Astro.props;
const whatsappUrl = `https://wa.me/${whatsappNumber.replace(/\D/g, "")}?text=${encodeURIComponent(whatsappMessage)}`;
---

<section class="contact section" id="contact">
  <div class="container contact__container">
    <header class="contact__header">
      <h2 class="contact__title">{title}</h2>
      <p class="contact__subtitle">{subtitle}</p>
    </header>

    <div class="contact__content">
      <a class="btn btn--whatsapp contact__cta" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
        {whatsappButtonText}
      </a>
    </div>

    <footer class="contact__footer">
      <img src={`${import.meta.env.BASE_URL}footer.png`} alt="Claudia Freire Advocacia" class="contact__footer-img" width="240" height="120" loading="lazy" />
    </footer>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-primary);
    color: var(--color-text-on-dark);
  }

  .contact__container {
    max-width: 32rem;
  }

  .contact__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .contact__title {
    color: var(--color-text-on-dark);
    margin-bottom: var(--space-sm);
  }

  .contact__subtitle {
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.9375rem;
    margin: 0;
    line-height: 1.6;
  }

  .contact__content {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .contact__cta {
    width: 100%;
    max-width: 20rem;
    display: inline-flex;
    justify-content: center;
    align-items: center;
  }

  .contact__footer {
    text-align: center;
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .contact__footer-img {
    display: block;
    width: 100%;
    max-width: 240px;
    height: auto;
    margin: 0 auto;
  }
</style>
