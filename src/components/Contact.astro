---
interface Props {
  title: string;
  subtitle: string;
  whatsappButtonText: string;
  whatsappNumber: string;
  whatsappMessage: string;
  phone?: string;
  email?: string;
}

const { title, subtitle, whatsappButtonText, whatsappNumber, whatsappMessage, phone, email } = Astro.props;
const whatsappUrl = `https://wa.me/${whatsappNumber.replace(/\D/g, "")}?text=${encodeURIComponent(whatsappMessage)}`;
---

<section class="contact section" id="contact">
  <div class="container contact__container">
    <header class="contact__header">
      <h2 class="contact__title">{title}</h2>
      <p class="contact__subtitle">{subtitle}</p>
    </header>

    <div class="contact__content">
      <a class="btn btn--whatsapp contact__cta" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
        {whatsappButtonText}
      </a>

      {(phone || email) && (
        <div class="contact__details">
          {phone && (
            <a class="contact__detail" href={`tel:${phone.replace(/\D/g, "")}`} aria-label="Telefone">
              <span class="contact__detail-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </span>
              <span>{phone}</span>
            </a>
          )}
          {email && (
            <a class="contact__detail" href={`mailto:${email}`} aria-label="E-mail">
              <span class="contact__detail-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
              </span>
              <span>{email}</span>
            </a>
          )}
        </div>
      )}
    </div>

    <footer class="contact__footer">
      <img src={`${import.meta.env.BASE_URL}footer.png`} alt="Claudia Freire Advocacia" class="contact__footer-img" width="240" height="120" loading="lazy" decoding="async" />
    </footer>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-primary);
    color: var(--color-text-on-dark);
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact__container {
    max-width: 32rem;
    width: 100%;
  }

  .contact__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .contact__title {
    color: var(--color-text-on-dark);
    margin-bottom: var(--space-sm);
  }

  .contact__subtitle {
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.9375rem;
    margin: 0;
    line-height: 1.6;
  }

  .contact__content {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .contact__cta {
    width: 100%;
    max-width: 20rem;
    display: inline-flex;
    justify-content: center;
    align-items: center;
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: center;
    margin-top: var(--space-xl);
  }

  .contact__detail {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: rgba(255, 255, 255, 0.95);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color var(--transition);
  }

  .contact__detail:hover {
    color: var(--color-text-on-dark);
  }

  .contact__detail-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-on-dark);
  }

  .contact__footer {
    text-align: center;
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .contact__footer-img {
    display: block;
    width: 100%;
    max-width: 240px;
    height: auto;
    margin: 0 auto;
  }
</style>
