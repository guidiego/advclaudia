---
interface Props {
  title: string;
  items: Array<{ title: string; description: string }>;
}

const { title, items } = Astro.props;
---

<section class="differentiators section" id="differentiators">
  <div class="container">
    <h2 class="differentiators__title">{title}</h2>
    <ul class="differentiators__list">
      {items.map((item) => (
        <li class="differentiators__item">
          <span class="differentiators__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
              <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
          </span>
          <div>
            <h3 class="differentiators__item-title">{item.title}</h3>
            <p class="differentiators__item-desc">{item.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .differentiators {
    background-color: var(--color-bg-warm);
  }

  .differentiators__title {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .differentiators__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-lg);
    max-width: 40rem;
    margin: 0 auto;
  }

  @media (min-width: 48rem) {
    .differentiators__list {
      grid-template-columns: repeat(2, 1fr);
      max-width: none;
    }
  }

  .differentiators__item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding: var(--space-lg);
    border-radius: var(--radius);
    background: #ffffff;
    border: 1px solid var(--color-border);
  }

  .differentiators__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(72, 18, 23, 0.12);
    color: var(--color-primary);
    border-radius: var(--radius);
  }

  .differentiators__icon svg {
    width: 24px;
    height: 24px;
  }

  .differentiators__item-title {
    margin-bottom: var(--space-xs);
    font-size: 1.0625rem;
  }

  .differentiators__item-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
