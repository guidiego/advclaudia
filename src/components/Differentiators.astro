---
interface Props {
  title: string;
  items: Array<{ title: string; description: string; icon?: string }>;
}

const { title, items } = Astro.props;

const icons: Record<string, string> = {
  personal: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><path d="m9 14 2 2 4-4"/>`,
  law: `<path d="M4 6h16v12H4z"/><path d="M12 6v12"/><path d="M8 10h8"/><path d="M8 14h8"/><path d="M12 2v4"/><path d="M12 18v4"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  flexibility: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/>`,
};

function getIconSvg(iconKey: string | undefined): string {
  const key = iconKey && icons[iconKey] ? iconKey : "personal";
  return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icons[key]}</svg>`;
}
---
<section class="differentiators section" id="differentiators">
  <div class="container">
    <h2 class="differentiators__title">{title}</h2>
    <ul class="differentiators__list">
      {items.map((item) => (
        <li class="differentiators__item">
          <span class="differentiators__icon" aria-hidden="true" set:html={getIconSvg(item.icon)} />
          <div>
            <h3 class="differentiators__item-title">{item.title}</h3>
            <p class="differentiators__item-desc">{item.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .differentiators {
    background-color: var(--color-bg-warm);
  }

  .differentiators__title {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .differentiators__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-lg);
    max-width: 40rem;
    margin: 0 auto;
  }

  @media (min-width: 48rem) {
    .differentiators__list {
      grid-template-columns: repeat(2, 1fr);
      max-width: none;
    }
  }

  .differentiators__item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding: var(--space-lg);
    border-radius: var(--radius);
    background: #ffffff;
    border: 1px solid var(--color-border);
  }

  .differentiators__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(72, 18, 23, 0.12);
    color: var(--color-primary);
    border-radius: var(--radius);
  }

  .differentiators__icon svg {
    width: 24px;
    height: 24px;
  }

  .differentiators__item-title {
    margin-bottom: var(--space-xs);
    font-size: 1.0625rem;
  }

  .differentiators__item-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
